# Next.js frontend + BFF - copy to frontend/.env
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="long-random-string"

# BFF → backend API (must match backend PORT; use 3001 when Next uses :3000).
INTERNAL_API_URL="http://127.0.0.1:3001"

# Must match backend/.env
INTERNAL_API_SECRET="change-me-to-a-long-random-value"

# NextAuth credentials login uses Prisma on the server side.
# Use the same cloud database URLs as backend/.env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require"
