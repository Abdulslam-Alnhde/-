# Next.js frontend + BFF — copy to frontend/.env
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="long-random-string"

# Where the browser loads the app; BFF proxies API calls here:
INTERNAL_API_URL="http://127.0.0.1:4000"

# Same value as backend INTERNAL_API_SECRET
INTERNAL_API_SECRET="generate-a-long-random-string"

# Client still needs Prisma only for NextAuth credentials login (authorize callback).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/exam_system"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/exam_system"
