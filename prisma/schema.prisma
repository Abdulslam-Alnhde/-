generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model College {
  id        String @id @default(uuid())
  name      String
  sortOrder Int    @default(0)
  users     User[]
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  role                  Role                   @default(TEACHER)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  department            String?
  /// رقم وظيفي / تعريف الموظف — مطلوب عند إنشاء الحساب من لوحة الإدارة
  employeeCode          String?                @unique
  hireDate              DateTime?
  jobTitle              String?
  nationalId            String?
  /// صلاحيات دقيقة (مفاتيح من lib/permissions)، المشرف يتجاوزها في المنطق
  permissionKeys        String[]               @default([])
  phone                 String?
  /// عند true: لا يعدّل المستخدم بياناته إلا بعد موافقة المشرف (أو عبر طلب تعديل)
  profileLocked         Boolean                @default(true)
  /// كلمة المرور المشفّرة (bcrypt) — مطلوبة لتسجيل الدخول بالبريد
  passwordHash          String?
  collegeId             String?
  exams                 Exam[]                 @relation("TeacherExams")
  notifications         Notification[]
  profileChangeRequests ProfileChangeRequest[]
  supportRepliesAsAdmin SupportTicket[]        @relation("AdminSupportReplies")
  supportTickets        SupportTicket[]        @relation("UserSupportTickets")
  college               College?               @relation(fields: [collegeId], references: [id])
}

/// طلب دعم فني — يرسله الموظف من الإعدادات، يجيب المشرف من لوحة الإدارة
model SupportTicket {
  id          String              @id @default(uuid())
  userId      String
  message     String
  /// مسارات عامة للصور المرفقة، مثل ["/uploads/support/.../file.png"]
  attachments Json                @default("[]")
  status      SupportTicketStatus @default(PENDING)
  adminReply  String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  repliedBy   User?               @relation("AdminSupportReplies", fields: [repliedById], references: [id])
  user        User                @relation("UserSupportTickets", fields: [userId], references: [id], onDelete: Cascade)
}

/// طلب تعديل بيانات الحساب من الموظف — يعتمد المشرف أو يرفض
model ProfileChangeRequest {
  id           String    @id @default(uuid())
  userId       String
  payload      Json
  status       String    @default("PENDING")
  adminNote    String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exam {
  id                 String          @id @default(uuid())
  createdAt          DateTime        @default(now())
  description        String?
  teacherId          String
  title              String
  updatedAt          DateTime        @updatedAt
  status             ExamStatus      @default(DRAFT)
  referenceMaterials Json?
  totalGrade         Float?
  type               String?
  /// ملاحظة اللجنة عند الرفض (أو آخر ملاحظة مراجعة) — تُعرض للمعلم مع الاختبار
  committeeFeedback  String?
  teacher            User            @relation("TeacherExams", fields: [teacherId], references: [id])
  questions          Question[]
  results            StudentResult[]
}

model Question {
  id            String     @id @default(uuid())
  examId        String
  type          String
  content       String
  correctAnswer String?
  options       Json?
  /// مجموع درجات المحاور الفرعية (قد يكون كسرياً مثل 7.5)
  points        Float      @default(1)
  modelAnswer   String?
  /// عرض للمستخدم: مثل 3.1 أو 3.2 داخل السؤال الرئيسي 3
  displayLabel  String?
  /// تعليمات المعلم للتصحيح الآلي لهذا السؤال
  teacherNote   String?
  keyPoints     KeyPoint[]
  exam          Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model KeyPoint {
  id         String   @id @default(uuid())
  questionId String
  point      String
  grade      Float
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model StudentResult {
  id         String   @id @default(uuid())
  examId     String
  studentId  String
  totalScore Float
  details    Json?
  gradedAt   DateTime @default(now())
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

enum Role {
  TEACHER
  COMMITTEE
  ADMIN
}

enum ExamStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PUBLISHED
}

enum SupportTicketStatus {
  PENDING
  ANSWERED
}
