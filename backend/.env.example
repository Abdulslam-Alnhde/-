# Backend API (Hono) — copy to backend/.env
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/exam_system"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/exam_system"

PORT=4000

# Must match INTERNAL_API_SECRET in frontend/.env (Next BFF)
INTERNAL_API_SECRET="generate-a-long-random-string"

# Support ticket uploads: directory the Next app serves as static files.
# Default when unset: ../frontend/public (from backend cwd).

# Optional: GET /api/debug/init-admin?secret=...
# DEBUG_INIT_ADMIN_SECRET=""
# ADMIN_BOOTSTRAP_EMPLOYEE_CODE="1001"
# ADMIN_BOOTSTRAP_EMAIL="admin@university.edu"
# ADMIN_BOOTSTRAP_PASSWORD="ChangeMe!"

# SMTP (optional)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SUPPORT_TO_EMAIL=""

# ============ AI ============
AI_PROVIDER="xai"
XAI_API_KEY="xai-..."
AI_API_KEY=""
AI_BASE_URL="https://api.x.ai/v1"
AI_MODELS="grok-4-1-fast-non-reasoning,grok-4-1-fast-reasoning"
AI_REQUEST_TIMEOUT_MS=600000
