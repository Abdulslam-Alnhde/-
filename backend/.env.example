# Backend API environment
# Monorepo dev: use 3001 so Next.js can keep 3000 (set INTERNAL_API_URL in frontend/.env).
PORT=3001

# Cloud PostgreSQL database.
# For Neon/Supabase, use the pooled URL for DATABASE_URL and the direct URL for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require"

# Must match frontend/.env
INTERNAL_API_SECRET="change-me-to-a-long-random-value"

# Initial admin created by `npm run db:seed`
ADMIN_EMAIL="admin@university.edu"
ADMIN_INITIAL_PASSWORD="change-me"
ADMIN_NAME="System Admin"
ADMIN_EMPLOYEE_CODE="A-0001"

# AI settings
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
AI_BASE_URL=""
# اقترح سلسلة نماذج احتياطية: عند نفاد حد نموذج واحد ينتقل النظام تلقائيًا
# للنموذج التالي. لكل نموذج Gemini حدّ يومي مستقل في الخطة المجانية.
AI_MODELS="gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash"
AI_REQUEST_TIMEOUT_MS="120000"
GEMINI_RATE_LIMIT_RETRIES="2"
GEMINI_RATE_LIMIT_BACKOFF_MS="3000"
STUDENT_FILE_PART_BATCH_SIZE="2"
STUDENT_FILE_PART_BATCH_CONCURRENCY="1"
STUDENT_FILE_PART_BATCH_MIN_PARTS="6"
STUDENT_INCLUDE_PDF_TEXT_CONTEXT="false"
STUDENT_MODEL_RETRIES="1"
STUDENT_MAX_MODEL_CALLS="12"
STUDENT_REASONING_EFFORT="low"
STUDENT_MISSING_RESCUE_LIMIT="8"
STUDENT_EXTRACT_MAX_TOKENS="8192"
STUDENT_EXTRACT_TIMEOUT_MS="300000"
