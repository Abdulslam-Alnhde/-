{
  "name": "university-exam-system-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:force": "cross-env FORCE_SEED=true tsx prisma/seed.ts",
    "test": "vitest run",
    "verify-ai": "node scripts/verify-ai-env.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.6.16",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^2.4.5",
    "server-only": "^0.0.1",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
