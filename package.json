{
  "name": "university-exam-system-monorepo",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "db:generate": "npm run db:generate -w backend",
    "db:push": "npm run db:push -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:seed:force": "npm run db:seed:force -w backend",
    "lint": "npm run lint -w frontend",
    "verify-ai": "npm run verify-ai -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
