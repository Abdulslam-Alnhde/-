DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/exam_system"

# NextAuth — يجب أن يطابق عنوان المتصفح حرفياً (مثلاً http://localhost:3000 أو http://127.0.0.1:3000 لجلسة منفصلة عن localhost)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="أنشئ_سلسلة_عشوائية_طويلة"

# Google AI Studio / Gemini API — يبدأ المفتاح بـ AIza
GEMINI_API_KEY="AIzaSyxxxxxxxx"

# اختياري: نموذج 2.5 الافتراضي (المستقر: gemini-2.5-flash). لاستخدام Pro: gemini-2.5-pro
# GEMINI_MODEL="gemini-2.5-flash"

# اختياري: احتياط للرؤية، مفصولة بفاصلة
# GEMINI_VISION_FALLBACK_MODELS="gemini-2.5-flash-lite,gemini-2.0-flash"
